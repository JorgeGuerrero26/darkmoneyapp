{
  "expo": {
    "name": "DarkMoney",
    "slug": "darkmoney",
    "version": "1.0.6",
    "scheme": "darkmoney",
    "orientation": "portrait",
    "icon": "./assets/images/logo-sin-fondo.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.darkmoney.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-playstore.png",
        "backgroundColor": "#05070B"
      },
      "package": "com.darkmoney.app",
      "versionCode": 7,
      "googleServicesFile": "./app/google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo-sin-fondo.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/notification-detection",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-sin-fondo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#05070B"
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "DarkMoney necesita acceso a la cámara para adjuntar comprobantes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DarkMoney necesita acceso a tus fotos para adjuntar comprobantes."
        }
      ],
      "expo-local-authentication",
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "DarkMoney usa el micrófono para registrar movimientos por voz.",
          "speechRecognitionPermission": "DarkMoney usa reconocimiento de voz para entender lo que dictas.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "extraProguardRules": "-keep class com.darkmoney.app.notificationdetection.** { *; }\n-keepclassmembers class * implements java.io.Serializable { static final long serialVersionUID; private static final java.io.ObjectStreamField[] serialPersistentFields; private void writeObject(java.io.ObjectOutputStream); private void readObject(java.io.ObjectInputStream); java.lang.Object writeReplace(); java.lang.Object readResolve(); }"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1290814f-9ea0-4f55-9973-3a3c32178cc5"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1290814f-9ea0-4f55-9973-3a3c32178cc5",
      "requestHeaders": {
        "expo-channel-name": "preview"
      },
      "checkAutomatically": "ON_LOAD"
    },
    "owner": "adriangmori"
  }
}
